{
	"name": "sentinel-supreme",
	"version": "0.0.0",
	"license": "MIT",
	"private": true,
	"scripts": {
		"start": "nx run-many --target=serve --all --parallel",
		"start:gateway": "nx serve gateway --output-style=stream",
		"start:dashboard": "nx serve dashboard",
		"start:log-processor": "nx serve log-processor --output-style=stream",
		"start:notification-service": "nx serve notification-service --output-style=stream",
		"start:ai-analysis-service": "nx serve ai-analysis-service --output-style=stream",
		"build:gateway": "nx build gateway",
		"build:dashboard": "nx build dashboard",
		"build:log-processor": "nx build log-processor",
		"build:notification-service": "nx build notification-service",
		"build:ai-analysis-service": "nx build ai-analysis-service",
		"lint": "nx run-many --target=lint --all",
		"lint:fix": "nx run-many --target=lint --all --fix",
		"format": "nx format:write",
		"format:check": "nx format:check",
		"test": "nx run-many --target=test --all",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f",
		"prepare": "husky",
		"seed:logs": "ts-node -P apps/log-processor/tsconfig.app.json apps/log-processor/src/scripts/seed-logs.ts"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"nx affected --target=lint --uncommitted --fix",
			"nx format:write --uncommitted"
		],
		"*.{json,md,css,html,yaml,yml}": [
			"nx format:write --uncommitted"
		]
	},
	"workspaces": [
		"apps/*",
		"libs/*"
	],
	"dependencies": {
