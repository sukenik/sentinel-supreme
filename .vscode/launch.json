{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Debug gateway with Nx",
			"runtimeExecutable": "npx",
			"runtimeArgs": ["nx", "serve", "gateway"],
			"env": {
				"NODE_OPTIONS": "--inspect=9229"
			},
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"],
			"sourceMaps": true,
			"outFiles": [
				"${workspaceFolder}/apps/gateway/dist/**/*.(m|c|)js",
				"!**/node_modules/**"
			]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug log-processor with Nx",
			"runtimeExecutable": "npx",
			"runtimeArgs": ["nx", "serve", "log-processor"],
			"env": {
				"NODE_OPTIONS": "--inspect=9230"
			},
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"],
			"sourceMaps": true,
			"outFiles": [
				"${workspaceFolder}/apps/log-processor/dist/**/*.(m|c|)js",
				"!**/node_modules/**"
			]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug notification-service with Nx",
			"runtimeExecutable": "npx",
			"runtimeArgs": ["nx", "serve", "notification-service"],
			"env": {
				"NODE_OPTIONS": "--inspect=9231"
			},
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"],
			"sourceMaps": true,
			"outFiles": [
				"${workspaceFolder}/apps/notification-service/dist/**/*.(m|c|)js",
				"!**/node_modules/**"
			]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug ai-service with Nx",
			"runtimeExecutable": "npx",
			"runtimeArgs": ["nx", "serve", "ai-service"],
			"env": {
				"NODE_OPTIONS": "--inspect=9232"
			},
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"],
			"sourceMaps": true,
			"outFiles": [
				"${workspaceFolder}/apps/ai-service/dist/**/*.(m|c|)js",
				"!**/node_modules/**"
			]
		}
	]
}
